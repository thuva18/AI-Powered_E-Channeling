{
  "expo": {
    "name": "Medicare E-Channeling",
    "slug": "medicare-echanneling",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiechannel.app"
    },
    "android": {
      "package": "com.aiechannel.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "scheme": "aiechannel",
    "extra": {
      "eas": {
        "projectId": "51e17cc9-63bf-47a8-9fb8-e74867e0c5e9"
      },
      "router": {}
    },
    "owner": "thuva18"
  }
}
