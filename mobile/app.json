{
  "expo": {
    "name": "AI E-Channeling",
    "slug": "ai-e-channeling",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aiechannel.app"
    },
    "android": {
      "package": "com.aiechannel.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "aiechannel",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id-here"
      }
    }
  }
}
